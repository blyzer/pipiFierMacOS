{
    "manifest_version": 3,
    "default_locale": "en",

    "name": "Picture-in-Picture Controller",
    "description": "Picture-in-Picture Web Extension",
    "version": "1.0",

//    "icons": {
//        "48": "images/icon-48.png",
//        "96": "images/icon-96.png",
//        "128": "images/icon-128.png",
//        "256": "images/icon-256.png",
//        "512": "images/icon-512.png"
//    },

    "background": {
        "scripts": [ "background.js" ],
        "type": "module"
    },

    "content_scripts": [{
        "matches": [
          "*://*.youtube.com/*",
          "*://*.netflix.com/*",
          "*://*.hulu.com/*",
          "*://*.disneyplus.com/*",
          "*://*.hbomax.com/*",
          "*://*.twitch.tv/*"
        ],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    }],
    "web_accessible_resources": [
      "PiP_Toolbar_Icon_white_new.svg",
      "PiP_Toolbar_Icon_white.svg",
      "PiP_Toolbar_Icon_new.svg"
    ]
    "action": {
        "default_popup": "popup.html",
        "default_icon": "PiP_Toolbar_Icon_white_new.svg"
    },

    "permissions": [
        "activeTab",
        "tabs"
      ],
}
